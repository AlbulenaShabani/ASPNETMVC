@using Silicon.ViewModels
@model AccountDetailsUserViewModel 

<div class="profile">
                <div class="profilePicture">
                    <div class="profile-pic">
                        <label class="-label" for="file">
                          <span class="glyphicon glyphicon-camera"></span>
                          <span>Change Image</span>
                        </label>
                        <input id="file" type="file" onchange="loadFile(event)"/>
                        <img src="/Image/noProfilePictureIcon.svg" alt="">



                    </div>
                    <div class="profileButton">

                        <p><strong>Name Lastname</strong></p>
                        <p>Email@hotmail.com</p>



                        <nav class="accountDetailsButton">
                            <a href="#"><i class="fa-solid fa-gear"></i>Account Details</a>
                        </nav>
                        <nav class="signOutButton">
                            <a href="#"><i class="fa-solid fa-arrow-right-from-bracket"></i>Sign Out</a>
                        </nav>



                    </div>


                </div>


                <div class="accountDetailsMain">

                    <form method="Post" asp-controller="AccountDetails" asp-action="Index">


                    <div class="accountDetailsHeader">
                        <h2><strong>Account Details</strong></h2>

                        <p><strong>Basic Info</strong></p>
                    </div>

                    <div class="firstNameLastname">
                        <div class="firstName input-validation-error">
                            <p><strong>FirstName</strong></p>
                            <input asp-for="UserForm.FirstName" placeholder="Firstname">
                        </div>

                        <div class="lastName input-validation-error">
                            <p><strong>LastName</strong></p>
                            <input asp-for="UserForm.LastName" placeholder="Lastname">
                        </div>
                    </div>

                    <div class="emailAddressPhoneNumber">
                        <div class="emailAddress input-validation-error">
                            <p><strong>Email Address</strong></p>
                            <input asp-for="UserForm.Email" placeholder="Email">
                        </div>

                        <div class="phoneNumber">
                            <p><strong>Phone Number</strong></p>
                            <input asp-for="UserForm.PhoneNumber" placeholder="PhoneNumber">
                        </div>

                    </div>

                    <div class="accountDetailsBio">
                        <p><strong>Bio</strong></p>
                        <input type="Bio" placeholder="Add a short bio...">
                    </div>

                    <div class="accountDetailsButtons">
                        <nav class="cancel">
                            <button type="Reset">Cancel</button>
                        </nav>

                        <nav class="saveChanges">
                            <button type="Submit">Save Changes</button>
                        </nav>

                    </div>



                    <div class="adressHeader">
                        <hr>
                        <p><strong>Address</strong></p>
                    </div>

                    <div class="adressLine1">
                        <p><strong>Address line 1</strong></p>
                        <input asp-for="AdressForm" placeholder="Enter your address line">
                    </div>

                    <div class="addressLine2">
                        <p><strong>Address line 2</strong></p>
                        <input asp-for="AdressForm" placeholder="Enter your 2 address line">
                    </div>


                    <div class="postalCodeCity">
                        <div class="postalCode">
                            <p><strong>Postal Code</strong></p>
                            <input asp-for="AdressForm" placeholder="Enter your postal code">
                        </div>

                        <div class="city">
                            <p><strong>Postal Code</strong></p>
                            <input asp-for="AdressForm" placeholder="Enter your city">
                        </div>



                    </div>


                    <div class="postalCodeCityButtons">
                        <nav class="cancel2">
                            <button type="Reset">Cancel</button>
                        </nav>

                        <nav class="saveChanges2">
                            <button type="Submit"> Save Changes</button>
                        </nav>

                    </div>

                    </form>

                </div>




            </div>